generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        Int      @id @default(autoincrement())
  amount    Float
  quantity  Int
  category  String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([category])
  @@map("transactions")
}
